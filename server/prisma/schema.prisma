datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String
  createdAt DateTime   @default(now())
  urls      ShortUrl[]

  @@map("users")
}

model ShortUrl {
  id          String    @id @default(uuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalUrl String
  shortCode   String    @unique
  customAlias String?   @unique
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  visits      Visit[]

  @@map("short_urls")
}

model Visit {
  id         String   @id @default(uuid())
  shortUrlId String
  shortUrl   ShortUrl @relation(fields: [shortUrlId], references: [id], onDelete: Cascade)
  visitedAt  DateTime @default(now())
  ipAddress  String
  userAgent  String
  country    String   @default("Unknown")
  device     String   @default("Unknown")
  browser    String   @default("Unknown")

  @@map("visits")
}
